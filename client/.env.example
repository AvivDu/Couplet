# Copy this file to .env and fill in the values
# Never commit .env to git

# Your deployed server URL — for production this is the AWS API Gateway URL
# For local simulator testing use: http://localhost:3000
# For local real-device testing use: http://<your-machine-ip>:3000
EXPO_PUBLIC_API_URL=https://<your-api-id>.execute-api.<region>.amazonaws.com

# AWS Cognito — get these from AWS Console after creating the User Pool
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
EXPO_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
