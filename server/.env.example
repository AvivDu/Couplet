# Copy this file to .env and fill in the values
# Never commit .env to git

# AWS Region
AWS_REGION=us-east-1

# AWS Cognito — get these from AWS Console after creating the User Pool
# User Pool ID format: us-east-1_XXXXXXXXX
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# App Client ID (the client you created with no secret)
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# AWS credentials — use temporary credentials from Learner Lab (AWS Details → Show)
# AWS_SESSION_TOKEN is required for Learner Lab temporary credentials
AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_SESSION_TOKEN=XXXXX...

# DynamoDB table names (must match tables created in AWS Console)
DYNAMODB_USERS_TABLE=Couplet-Users
DYNAMODB_COUPONS_TABLE=Couplet-Coupons
DYNAMODB_GROUPS_TABLE=Couplet-Groups

# Server port (optional, defaults to 3000)
PORT=3000

# Google Places API key — used for the "Where to use" store locator feature
# Get one at console.cloud.google.com → APIs & Services → Credentials → Create Credentials → API Key
# Enable "Places API" on the same project
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
