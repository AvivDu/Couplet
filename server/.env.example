# Copy this file to .env and fill in the values
# Never commit .env to git

# MongoDB connection string from MongoDB Atlas (or local MongoDB)
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cuplet?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Server port (optional, defaults to 3000)
PORT=3000
